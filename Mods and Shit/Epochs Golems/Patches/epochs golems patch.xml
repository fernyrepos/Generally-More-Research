		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>/Defs/ThingDef[defName="DV_Golem_PyrinthTalon"]/recipeMaker/researchPrerequisite</xpath>
					<value>
						<researchPrerequisite>Ferny_PyrinthTalon</researchPrerequisite>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>/Defs/RecipeDef[defName="DV_Golem_InstallPyrinthTalon"]</xpath>
					<value>
						<researchPrerequisite>Ferny_PyrinthTalon</researchPrerequisite>
