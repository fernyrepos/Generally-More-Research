<?xml version="1.0" encoding="utf-8" ?>
<Patch>

	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/RecipeDef[defName="VFEM2_Make_Hardweave"]/researchPrerequisite</xpath>
		<match Class="PatchOperationReplace">
			<xpath>/Defs/RecipeDef[defName="VFEM2_Make_Hardweave"]/researchPrerequisite</xpath>
			<value>
				<researchPrerequisite>Ferny_Hardweave</researchPrerequisite>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/RecipeDef[defName="VFEM2_Make_Hardweave"]</xpath>
			<value>
				<researchPrerequisite>Ferny_Hardweave</researchPrerequisite>
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/RecipeDef[defName="VFEM2_Make_Hayweave"]/researchPrerequisite</xpath>
		<match Class="PatchOperationReplace">
			<xpath>/Defs/RecipeDef[defName="VFEM2_Make_Hayweave"]/researchPrerequisite</xpath>
			<value>
				<researchPrerequisite>Ferny_Hayweave</researchPrerequisite>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/RecipeDef[defName="VFEM2_Make_Hayweave"]</xpath>
			<value>
				<researchPrerequisite>Ferny_Hayweave</researchPrerequisite>
			</value>
		</nomatch>
	</Operation>

</Patch>
