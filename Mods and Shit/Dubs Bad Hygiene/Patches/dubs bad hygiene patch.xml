			<xpath>/Defs/ThingDef[defName="PitLatrine"]/researchPrerequisites</xpath>
			<value>
				<researchPrerequisites>
					<li>Ferny_Latrine</li>
				</researchPrerequisites>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/ThingDef[defName="PitLatrine"]</xpath>
			<value>
				<researchPrerequisites>
					<li>Ferny_Latrine</li>
				</researchPrerequisites>
			</value>
		</nomatch>
	</Operation>

</Patch>
